# ============================================================
# Living Well Communities — Environment Configuration
# Copy this file to .env and update the values below.
#   cp .env.example .env
# ============================================================

# ── Database ───────────────────────────────────────────────────
POSTGRES_USER=livingwell
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here
POSTGRES_DB=livingwell

# ── Backend ────────────────────────────────────────────────────
ENVIRONMENT=production
JWT_SECRET_KEY=CHANGE_ME_run_openssl_rand_hex_32
SEED_DB=true

# ── Frontend ───────────────────────────────────────────────────
# For IP-only access (no domain): http://YOUR_DROPLET_IP:8000
# For domain access with Caddy:   https://yourdomain.com
NEXT_PUBLIC_API_URL=http://YOUR_DROPLET_IP:8000
FRONTEND_URL=http://YOUR_DROPLET_IP:3000

# ── AI & Integrations (optional — can also be set via Settings UI) ──
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-20250514

# ── Google Maps (frontend only) ───────────────────────────────
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
