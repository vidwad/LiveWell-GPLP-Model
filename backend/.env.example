# ============================================================
# Living Well Communities — Backend Environment Variables
# ============================================================
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# ============================================================

# --- Database ---
# For local development (SQLite): leave DATABASE_URL blank.
# For production (PostgreSQL): set the full connection string.
# DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres

# --- Authentication ---
# MUST change in production. Generate with: openssl rand -hex 32
JWT_SECRET_KEY=supersecretkey
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Frontend URL (for CORS) ---
# Set to your Vercel deployment URL in production.
# FRONTEND_URL=https://your-app.vercel.app

# --- AI & Integrations (optional — can also be set via Settings page) ---
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# CLAUDE_MODEL=claude-opus-4-7
