# ============================================================
# Living Well Communities — Frontend Environment Variables
# ============================================================
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local to version control.
# ============================================================

# --- API URL ---
# For local development:
NEXT_PUBLIC_API_URL=http://localhost:8000

# For production (set in Vercel dashboard):
# NEXT_PUBLIC_API_URL=https://livingwell-api.onrender.com

# --- Google Maps (for Area Research map view) ---
# Get a key at https://console.cloud.google.com — enable Maps JavaScript API
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
